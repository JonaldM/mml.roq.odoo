<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_roq" model="ir.ui.view">
        <field name="name">res.config.settings.view.roq</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="ROQ Forecast" string="ROQ Forecast" name="mml_roq_forecast">

                    <block title="Demand &amp; Forecast" name="roq_demand_setting_container">
                        <setting string="Default Lead Time (Days)"
                                 help="System-wide default. Overridden per-supplier.">
                            <field name="roq_default_lead_time_days"/>
                        </setting>
                        <setting string="Default Review Interval (Days)">
                            <field name="roq_default_review_interval_days"/>
                        </setting>
                        <setting string="Lookback Weeks"
                                 help="156 = 3 years history">
                            <field name="roq_lookback_weeks"/>
                        </setting>
                        <setting string="SMA Window (Weeks)">
                            <field name="roq_sma_window_weeks"/>
                        </setting>
                        <setting string="Min N Value"
                                 help="Minimum data points for reliable std dev">
                            <field name="roq_min_n_value"/>
                        </setting>
                    </block>

                    <block title="ABCD Classification" name="roq_abc_setting_container">
                        <setting string="ABC Dampener (Weeks)">
                            <field name="roq_abc_dampener_weeks"/>
                        </setting>
                    </block>

                    <block title="Ordering &amp; Containers" name="roq_ordering_setting_container">
                        <setting string="Container LCL Threshold (%)">
                            <field name="roq_container_lcl_threshold_pct"/>
                        </setting>
                        <setting string="Enforce Supplier MOQs"
                                 help="When enabled, orders below the supplier minimum order quantity are raised to the minimum and extra units allocated to the warehouse with lowest cover. When disabled, the MOQ flag is shown but quantities are unchanged.">
                            <field name="roq_enable_moq_enforcement" widget="boolean_toggle"/>
                        </setting>
                    </block>

                </app>
            </xpath>
        </field>
    </record>
</odoo>
