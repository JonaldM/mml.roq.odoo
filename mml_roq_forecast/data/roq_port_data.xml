<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!--
        Freight port seed data — UN/LOCODE format.
        noupdate="1" means these records are only created on first install;
        manual edits in Odoo are preserved on module upgrade.
        Add new ports via the Configuration → Freight Ports menu.
    -->

    <!-- ===================== CHINA — Origin ports ===================== -->
    <record id="port_cnsha" model="roq.port">
        <field name="code">CNSHA</field>
        <field name="name">Shanghai</field>
        <field name="country_id" ref="base.cn"/>
    </record>

    <record id="port_cnngb" model="roq.port">
        <field name="code">CNNGB</field>
        <field name="name">Ningbo-Zhoushan</field>
        <field name="country_id" ref="base.cn"/>
